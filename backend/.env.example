# ============================================
# FOUNDER COPILOT - Environment Configuration
# ============================================

# AWS Credentials (for Amazon Bedrock / Nova AI)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ── Amazon Nova Model IDs (cross-region inference profiles — required for on-demand throughput) ──
NOVA_2_LITE_MODEL_ID=us.amazon.nova-2-lite-v1:0
NOVA_2_PRO_MODEL_ID=us.amazon.nova-2-pro-v1:0
NOVA_PREMIER_MODEL_ID=us.amazon.nova-premier-v1:0
NOVA_MICRO_MODEL_ID=us.amazon.nova-micro-v1:0

# Demo Mode — set to true to run with sample outputs (no AWS needed)
# Auto-enabled when AWS credentials are missing
DEMO_MODE=false

# App Settings
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
